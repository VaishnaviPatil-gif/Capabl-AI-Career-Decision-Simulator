generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {

  id              Int      @id @default(autoincrement())

  name            String
  email           String   @unique
  password        String

  college         String?
  age             Int?
  bio             String?

  github          String?
  linkedin        String?

  resume          String?
  resumeName      String?
  profilePic      String?

  careerGoal      String?

  createdAt       DateTime @default(now())

  skills          Skill[]
  roadmaps        Roadmap[]
  achievements    Achievement[]

  aiAnalysis      AIAnalysis?

  skillProgress   SkillProgress[]
  weeklyProgress  WeeklyTaskProgress[]

  interviews      InterviewSession[]

}

model InterviewSession {

  id              Int      @id @default(autoincrement())

  topic           String
  level           String   @default("medium")
  durationKey     String   @default("medium")
  totalQuestions  Int      @default(5)

  status          String   @default("active")

  transcript      Json?

  score           Int?
  strengths       String[]
  weaknesses      String[]
  advice          String[]
  summary         String?

  startedAt       DateTime @default(now())
  finishedAt      DateTime?

  userId          Int
  user            User     @relation(fields: [userId], references: [id])
}

model SkillProgress {

  id          Int      @id @default(autoincrement())

  skillName   String
  source      String?  @default("manual")
  completedAt DateTime @default(now())

  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, skillName])
}

model WeeklyTaskProgress {

  id          Int      @id @default(autoincrement())

  week        Int
  taskKey     String
  completedAt DateTime @default(now())

  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, week, taskKey])
}

model Skill {

  id              Int      @id @default(autoincrement())

  name            String

  userId          Int
  user            User     @relation(fields: [userId], references: [id])

}

model Roadmap {

  id              Int      @id @default(autoincrement())

  title           String
  progress        Int      @default(0)

  description     String?
  deadline        String?

  userId          Int
  user            User     @relation(fields: [userId], references: [id])

}

model Achievement {

  id              Int      @id @default(autoincrement())

  title           String
  description     String?

  createdAt       DateTime @default(now())

  userId          Int
  user            User     @relation(fields: [userId], references: [id])

}

model AIAnalysis {

  id                        Int      @id @default(autoincrement())

  // BASIC INFO

  bio                       String?
  phone                     String?
  location                  String?

  // EDUCATION

  degree                    String?
  specialization            String?
  collegeName               String?

  startYear                 String?
  endYear                   String?

  cgpa                      String?

  // AI SCORES

  readinessScore            Int?
  atsScore                  Int?
  resumeScore               Int?

  // CAREER FIT

  careerFit                 String?

  // ARRAYS

  languages                 String[]

  strengths                 String[]
  weaknesses                String[]

  missingSkills             String[]
  extractedSkills           String[]

  aiSuggestions             String[]

  // RECOMMENDATIONS

  recommendedRoles          String[]
  recommendedCourses        String[]
  recommendedProjects       String[]
  recommendedInternships    String[]

  whyRecommendations        String[]

  // EXPERIENCE

  internshipExperience      String[]
  certifications            String[]

  // PROJECTS

  projectTitles             String[]
  // PROJECTS

savedProjects             String[]
projectStatuses           String[]
projectDescriptions       String[]
projectTechnologies       String[]
projectImages             String[]

recommendedProjectTitles  String[]
recommendedProjectDesc    String[]
recommendedProjectTags    String[]

totalProjects             Int?
completedProjects         Int?
inProgressProjects        Int?

  // SOCIAL ANALYSIS

  githubScore               Int?
  linkedinScore             Int?

  // FINAL AI SUMMARY

  aiSummary                 String?

  createdAt                 DateTime @default(now())

  // RELATION

  userId                    Int      @unique

  user                      User     @relation(fields: [userId], references: [id])

}