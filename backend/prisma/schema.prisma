generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int                  @id @default(autoincrement())
  name           String
  email          String               @unique
  password       String
  createdAt      DateTime             @default(now())
  age            Int?
  bio            String?
  college        String?
  github         String?
  linkedin       String?
  profilePic     String?
  resume         String?
  careerGoal     String?
  resumeName     String?
  phone          String?
  portfolio      String?
  aiAnalysis     AIAnalysis?
  achievements   Achievement[]
  interviews     InterviewSession[]
  roadmaps       Roadmap[]
  skills         Skill[]
  skillProgress  SkillProgress[]
  weeklyProgress WeeklyTaskProgress[]
  weeklyGoals         WeeklyGoal[]
  simulationSnapshots SimulationSnapshot[]
}

model InterviewSession {
  id                  Int       @id @default(autoincrement())
  level               String    @default("medium")
  totalQuestions      Int       @default(6)
  status              String    @default("scheduled")
  transcript          Json?
  score               Int?
  strengths           String[]
  weaknesses          String[]
  advice              String[]
  summary             String?
  startedAt           DateTime  @default(now())
  finishedAt          DateTime?
  userId              Int
  agentPrompt         String?
  careerFit           String?
  clarityScore        Int?
  communicationScore  Int?
  confidenceScore     Int?
  contextSnapshot     Json?
  culturalFitScore    Int?
  durationSeconds     Int?
  format              String    @default("one-on-one")
  improvementPlan     String[]
  interviewerName     String?   @default("Rexa")
  medium              String    @default("ai")
  mode                String    @default("text")
  problemSolvingScore Int?
  purpose             String    @default("technical")
  readinessScore      Int?
  retellAgentId       String?
  retellCallId        String?   @unique
  role                String    @default("standard")
  skillGaps           String[]
  stage               String    @default("first")
  technicalScore      Int?
  turns               Json?
  voiceProvider       String?
  user                User      @relation(fields: [userId], references: [id])
}

model SkillProgress {
  id          Int      @id @default(autoincrement())
  skillName   String
  source      String?  @default("manual")
  completedAt DateTime @default(now())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, skillName])
}

model WeeklyTaskProgress {
  id          Int      @id @default(autoincrement())
  week        Int
  taskKey     String
  completedAt DateTime @default(now())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, week, taskKey])
}

model Skill {
  id     Int    @id @default(autoincrement())
  name   String
  userId Int
  user   User   @relation(fields: [userId], references: [id])
}

model Roadmap {
  id          Int     @id @default(autoincrement())
  title       String
  progress    Int     @default(0)
  userId      Int
  deadline    String?
  description String?
  user        User    @relation(fields: [userId], references: [id])
}

model Achievement {
  id          Int      @id @default(autoincrement())
  title       String
  userId      Int
  createdAt   DateTime @default(now())
  description String?
  user        User     @relation(fields: [userId], references: [id])
}

model AIAnalysis {
  id                       Int      @id @default(autoincrement())
  careerFit                String?
  userId                   Int      @unique
  bio                      String?
  collegeName              String?
  degree                   String?
  endYear                  String?
  location                 String?
  phone                    String?
  specialization           String?
  startYear                String?
  aiSummary                String?
  atsScore                 Int?
  certifications           String[]
  cgpa                     String?
  createdAt                DateTime @default(now())
  githubScore              Int?
  internshipExperience     String[]
  linkedinScore            Int?
  projectTechnologies      String[]
  projectTitles            String[]
  recommendedCourses       String[]
  recommendedInternships   String[]
  recommendedProjects      String[]
  recommendedRoles         String[]
  resumeScore              Int?
  weaknesses               String[]
  whyRecommendations       String[]
  readinessScore           Int?
  strengths                String[]
  missingSkills            String[]
  aiSuggestions            String[]
  extractedSkills          String[]
  languages                String[]
  completedProjects        Int?
  inProgressProjects       Int?
  projectDescriptions      String[]
  projectImages            String[]
  projectStatuses          String[]
  recommendedProjectDesc   String[]
  recommendedProjectTags   String[]
  recommendedProjectTitles String[]
  savedProjects            String[]
  totalProjects            Int?
  requiredSkills           String[] @default([])
  roleIntelligence         Json?
  roleGoalSnapshot         String?
  matchScore           Int?
  profileCompleteness  Int?
  canonicalAnalysis    Json?
  evidenceSummary      Json?
  skillProficiency     Json?
  roadmapPlan          Json?
  user                     User     @relation(fields: [userId], references: [id])
}

model WeeklyGoal {
  id           String   @id @default(uuid())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  targetRole   String
  skillsFocus  String[]
  weekStart    DateTime
  weekGoal     String?
  dailyPlan    Json?
  expectedGain Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([userId, weekStart])
}

model SimulationSnapshot {
  id             String   @id @default(uuid())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  skillsToggled  Json
  // [{ "skill": "Docker", "gain": 5 }, ...] — Json keeps per-skill gain, avoids a 2nd migration
  projectedScore Int
  delta          Int
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}
