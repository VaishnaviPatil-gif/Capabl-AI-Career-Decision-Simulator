generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {

  id              Int      @id @default(autoincrement())

  name            String
  email           String   @unique
  password        String

  college         String?
  age             Int?
  bio             String?

  github          String?
  linkedin        String?

  resume          String?
  resumeName      String?
  profilePic      String?

  careerGoal      String?

  createdAt       DateTime @default(now())

  skills          Skill[]
  roadmaps        Roadmap[]
  achievements    Achievement[]

  aiAnalysis      AIAnalysis?

  skillProgress   SkillProgress[]
  weeklyProgress  WeeklyTaskProgress[]

  interviews      InterviewSession[]

}

model InterviewSession {

  id              Int      @id @default(autoincrement())

  // -------------------------------------------------------------------------
  // Type taxonomy (purpose × role × stage × medium × format)
  //   purpose: screening | technical | behavioral | situational | case |
  //            cultural-fit | competency | stress
  //   role:    coding | portfolio | presentation | working |
  //            resume-discussion | dsa | standard
  //   stage:   first | second | final
  //   medium:  ai | video | phone
  //   format:  one-on-one | panel | sequential
  // -------------------------------------------------------------------------
  purpose         String   @default("technical")
  role            String   @default("standard")
  stage           String   @default("first")
  medium          String   @default("ai")
  format          String   @default("one-on-one")

  level           String   @default("medium")
  totalQuestions  Int      @default(6)

  // -------------------------------------------------------------------------
  // Session state
  //   status: scheduled | in_progress | finished | abandoned
  //   mode:   voice (Retell) | text (fallback when no RETELL_API_KEY)
  // -------------------------------------------------------------------------
  status          String   @default("scheduled")
  mode            String   @default("text")

  // Personalisation snapshot — captured at start so re-running analytics is
  // deterministic even if the user's profile changes later.
  contextSnapshot Json?
  agentPrompt     String?
  careerFit       String?
  interviewerName String?  @default("Rexa")

  // Retell integration
  retellCallId    String?  @unique
  retellAgentId   String?
  voiceProvider   String?

  // Conversation data
  //   transcript: raw turns from voice call [{ role, text, ts }]
  //   turns:      logical Q-A pairs with per-turn evaluation
  //               [{ question, answer, feedback, dims:{tech,comm,prob,conf,clar,fit} }]
  transcript      Json?
  turns           Json?

  // -------------------------------------------------------------------------
  // Evaluation (6-dimension rubric with weights tech 30 / comm 25 / prob 20 /
  // conf 10 / clar 10 / fit 5)
  // -------------------------------------------------------------------------
  score                Int?
  technicalScore       Int?
  communicationScore   Int?
  problemSolvingScore  Int?
  confidenceScore      Int?
  clarityScore         Int?
  culturalFitScore     Int?

  strengths       String[]
  weaknesses      String[]
  skillGaps       String[]
  advice          String[]
  improvementPlan String[]
  summary         String?
  readinessScore  Int?

  startedAt       DateTime @default(now())
  finishedAt      DateTime?
  durationSeconds Int?

  userId          Int
  user            User     @relation(fields: [userId], references: [id])
}

model SkillProgress {

  id          Int      @id @default(autoincrement())

  skillName   String
  source      String?  @default("manual")
  completedAt DateTime @default(now())

  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, skillName])
}

model WeeklyTaskProgress {

  id          Int      @id @default(autoincrement())

  week        Int
  taskKey     String
  completedAt DateTime @default(now())

  userId      Int
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, week, taskKey])
}

model Skill {

  id              Int      @id @default(autoincrement())

  name            String

  userId          Int
  user            User     @relation(fields: [userId], references: [id])

}

model Roadmap {

  id              Int      @id @default(autoincrement())

  title           String
  progress        Int      @default(0)

  description     String?
  deadline        String?

  userId          Int
  user            User     @relation(fields: [userId], references: [id])

}

model Achievement {

  id              Int      @id @default(autoincrement())

  title           String
  description     String?

  createdAt       DateTime @default(now())

  userId          Int
  user            User     @relation(fields: [userId], references: [id])

}

model AIAnalysis {

  id                        Int      @id @default(autoincrement())

  // BASIC INFO

  bio                       String?
  phone                     String?
  location                  String?

  // EDUCATION

  degree                    String?
  specialization            String?
  collegeName               String?

  startYear                 String?
  endYear                   String?

  cgpa                      String?

  // AI SCORES

  readinessScore            Int?
  atsScore                  Int?
  resumeScore               Int?

  // CAREER FIT

  careerFit                 String?
  requiredSkills            String[] @default([])
  roleIntelligence          Json?
  roleGoalSnapshot          String?

  // ARRAYS

  languages                 String[]

  strengths                 String[]
  weaknesses                String[]

  missingSkills             String[]
  extractedSkills           String[]

  aiSuggestions             String[]

  // RECOMMENDATIONS

  recommendedRoles          String[]
  recommendedCourses        String[]
  recommendedProjects       String[]
  recommendedInternships    String[]

  whyRecommendations        String[]

  // EXPERIENCE

  internshipExperience      String[]
  certifications            String[]

  // PROJECTS

  projectTitles             String[]
  // PROJECTS

savedProjects             String[]
projectStatuses           String[]
projectDescriptions       String[]
projectTechnologies       String[]
projectImages             String[]

recommendedProjectTitles  String[]
recommendedProjectDesc    String[]
recommendedProjectTags    String[]

totalProjects             Int?
completedProjects         Int?
inProgressProjects        Int?

  // SOCIAL ANALYSIS

  githubScore               Int?
  linkedinScore             Int?

  // FINAL AI SUMMARY

  aiSummary                 String?

  createdAt                 DateTime @default(now())

  // RELATION

  userId                    Int      @unique

  user                      User     @relation(fields: [userId], references: [id])

}
